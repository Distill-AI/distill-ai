NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=distill_ai
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false

# ── Redis (shared by RedisService and Bull) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_TLS=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── API ───────────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
CORS_ORIGIN=*

# ── Reference feature: Bull queue worker (remove if not using queues) ─────────
QUEUE_CONCURRENCY=3
QUEUE_MAX_ATTEMPTS=3

# ── Reference feature: DLQ alert (remove if not using DLQ) ───────────────────
DLQ_ALERT_THRESHOLD=10
ALERT_EMAIL=admin@example.com
EMAIL_FROM=App <noreply@example.com>

# ── Docker / GHCR (CI sets these; leave blank for local dev — compose uses its own defaults) ──
GHCR_REGISTRY=
IMAGE_TAG=local

# ── Port overrides (set per environment on the server; defaults work locally) ─
CLIENT_PORT=80
API_PORT=3000

# ── Worker scaling ────────────────────────────────────────────────────────────
WORKER_INSTANCES=1

# ── Database (connection string — alternative to individual DB vars above) ────
DATABASE_URL=

# ── Object storage (PDFs, attachments, exported quotes) ──────────────────────
OBJECT_STORE_URL=

# ── AI — LLM (ingestion, extraction, quote generation) ───────────────────────
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=


# ── AI — Embeddings + Vector store (semantic catalog mapping) ─────────────────
EMBEDDINGS_PROVIDER=
EMBEDDINGS_MODEL=
EMBEDDINGS_DIMENSIONS=
EMBEDDINGS_API_KEY=


VECTOR_STORE=pgvector

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_CONCURRENCY=3
SWEEP_STALE_SECONDS=60

# ── Quote rules ───────────────────────────────────────────────────────────────
MATCH_THRESHOLD=0.70       # minimum confidence to accept a catalog match
AUTO_THRESHOLD=0.95        # confidence above which a quote skips HITL and auto-sends
AUTO_SEND_CAP_MINOR=       # max line-item value (minor units) eligible for auto-send

# ── Auth (NFR-SEC-5) ──────────────────────────────────────────────────────────
AUTH_ENABLED=false      # false=demo (all pass), true=production (JWT+RLS)
JWT_SECRET=              # required when AUTH_ENABLED=true
JWT_EXPIRY_MS=3600000   # JWT token expiry in ms (default 1 hour)

# ── Feature flags ─────────────────────────────────────────────────────────────
DEMO_MODE=false

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
