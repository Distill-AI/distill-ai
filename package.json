{
  "name": "nestjs-fullstack-starter",
  "version": "1.0.0",
  "description": "A fullstack NestJS starter with PostgreSQL, Redis, Bull queues, SSE, and React",
  "author": "",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "worker:dev": "SERVICE_NAME=job-scheduler-worker ts-node -r tsconfig-paths/register src/worker.ts",
    "worker:prod": "SERVICE_NAME=job-scheduler-worker node dist/worker",
    "dev": "concurrently -n api,worker -c cyan,green \"pnpm start:dev\" \"pnpm worker:dev\"",
    "dev:4workers": "concurrently -n api,w1,w2,w3,w4 -c cyan,green,green.dim,yellow,yellow.dim \"pnpm start:dev\" \"pnpm worker:dev\" \"pnpm worker:dev\" \"pnpm worker:dev\" \"pnpm worker:dev\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typeorm": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js",
    "migration:create": "pnpm run typeorm migration:create",
    "migration:generate": "pnpm run typeorm migration:generate -d src/database/data-source.ts",
    "migration:run": "pnpm run typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm migration:revert -d src/database/data-source.ts",
    "migration:show": "pnpm run typeorm migration:show -d src/database/data-source.ts",
    "db:reset": "ts-node -r tsconfig-paths/register scripts/reset-db.ts",
    "seed:db": "ts-node -r tsconfig-paths/register scripts/seed-db.ts",
    "seed:live": "ts-node scripts/seed-live.ts",
    "perf": "ts-node scripts/perf-test.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@hng-sdk/orm": "0.0.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "@sentry/nestjs": "10.58.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bull": "^4.10.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "msgpackr-extract"
    ],
    "overrides": {
      "multer": "^2.2.0"
    }
  }
}
