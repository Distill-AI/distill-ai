# Stage 1 — Vite production build
FROM node:22-alpine AS builder
WORKDIR /app
RUN npm install -g pnpm@11

# Copy workspace manifest + root lockfile so pnpm can resolve deps correctly
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY client/package.json ./client/package.json

# Install only client dependencies — skips all NestJS/server packages
RUN pnpm install --frozen-lockfile --filter client

# Copy client source after the install layer so Docker cache is reused on source-only changes
COPY client/ ./client/

# VITE_API_URL is intentionally not set here — nginx proxies /api at runtime
RUN pnpm --filter client build

# Stage 2 — nginx-unprivileged serves static files and proxies /api to the api container
# Uses nginxinc/nginx-unprivileged which runs as uid 101 (nginx) and listens on 8080
FROM nginxinc/nginx-unprivileged:alpine AS runner
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/client/dist /usr/share/nginx/html
EXPOSE 8080
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:8080/health.txt || exit 1
