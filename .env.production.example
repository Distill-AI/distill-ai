# Production env template for the Alibaba Cloud deployment (Singapore).
# Place this as the .env on the ECS host (per environment), e.g.
#   /opt/distill-ai/staging/.env  and  /opt/distill-ai/prod/.env
# Do NOT commit real secrets. Values in <...> are filled from provisioning.

NODE_ENV=production
PORT=3000

# PostgreSQL (runs as a container on the ECS host via docker-compose; pgvector image)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=<db-user>
DATABASE_PASSWORD=<db-password>
DATABASE_NAME=distill_ai
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false

# Redis (runs as a container on the ECS host via docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<redis-password>
REDIS_USERNAME=
REDIS_TLS=false

LOG_LEVEL=info
SWAGGER_ENABLED=true
CORS_ORIGIN=<client-origin-url>

QUEUE_CONCURRENCY=3
QUEUE_MAX_ATTEMPTS=3
DLQ_ALERT_THRESHOLD=10
ALERT_EMAIL=admin@example.com
EMAIL_FROM=App <noreply@example.com>
WORKER_INSTANCES=1

# Object storage (OSS bucket for the client build + generated PDFs)
OBJECT_STORE_URL=<oss-bucket-endpoint>

# AI, LLM (Qwen Cloud, Singapore, OpenAI-compatible endpoint)
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=<qwen-sk-key>

# AI, embeddings (Qwen text-embedding-v4, 1024-dim, matches skus.embedding vector(1024))
EMBEDDINGS_PROVIDER=qwen
EMBEDDINGS_MODEL=text-embedding-v4
EMBEDDINGS_DIMENSIONS=1024
EMBEDDINGS_API_KEY=<qwen-sk-key>

VECTOR_STORE=pgvector

PIPELINE_CONCURRENCY=3
SWEEP_STALE_SECONDS=60

MATCH_THRESHOLD=0.70
AUTO_THRESHOLD=0.95
AUTO_SEND_CAP_MINOR=

# Secure by default. Demo/dev deployments may explicitly override to false until the
# RBAC guard (NFR-SEC-5 AuthModule) is wired; production should keep this true.
AUTH_ENABLED=true
DEMO_MODE=false

OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
